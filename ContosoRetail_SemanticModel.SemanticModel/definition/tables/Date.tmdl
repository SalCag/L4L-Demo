	partition Date-1df832c2-1fec-45eb-8a33-4ebef966e9ea = m
		mode: import
		source =
				let
				    Source = Sql.Database(SourceServer, Test_Demo_DB, [Query="SELECT [DateKey]#(lf)        ,[Date]#(lf)        ,[Year]#(lf)        ,[Semester]#(lf)        ,[EnglishSemesterName]          AS  [SemesterName]#(lf)        ,[EnglishYearSemesterName]      AS  [YearSemesterName]#(lf)        ,[SemesterKey]#(lf)        ,[Quarter]#(lf)        ,[EnglishQuarterName]           AS  [QuarterName]#(lf)        ,[EnglishYearQuarterName]       AS  [YearQuarterName]#(lf)        ,[QuarterKey]#(lf)        ,[QuarterName]#(lf)        ,[YearQuarterName]#(lf)        ,[Month]#(lf)        ,[MonthKey]#(lf)        ,[MonthKeyPY]#(lf)        ,[YearMonth]#(lf)        ,[FirstDayOfMonth]#(lf)        ,[FirstDayOfMonthKey]#(lf)        ,[LastDayOfMonth]#(lf)        ,[LastDayOfMonthKey]#(lf)        ,[FirstDayOfMonthPY]#(lf)        ,[FirstDayOfMonthPYKey]#(lf)        ,[LastDayOfMonthPY]#(lf)        ,[LastDayOfMonthPYKey]#(lf)        ,[EnglishMonthName]             AS  [MonthName]#(lf)        ,[EnglishMonthShortName]        AS  [MonthShortName]#(lf)        ,[EnglishYearMonthShortName]    AS  [YearMonthShortName]#(lf)        ,[Week]#(lf)        ,[WeekKey]#(lf)        ,[WeekKeyPY]#(lf)        ,[YearOfWeek]#(lf)        ,[YearWeek]#(lf)        ,[DayOfYear]#(lf)        ,[DayOfYearKey]#(lf)        ,[DayOfMonth]#(lf)        ,[DayOfWeek]#(lf)        ,[DayOfWeekKey]#(lf)        ,[FirstDayOfWeekDate]#(lf)        ,[FirstDayOfWeekDateKey]#(lf)        ,[LastDayOfWeekDate]#(lf)        ,[LastDayOfWeekDateKey]#(lf)        ,[FirstDayOfWeekDatePY]#(lf)        ,[FirstDayOfWeekDatePYKey]#(lf)        ,[LastDayOfWeekDatePY]#(lf)        ,[LastDayOfWeekDatePYKey]#(lf)        ,[EnglishDayOfWeekName]         AS  [DayOfWeekName]#(lf)        ,[EnglishDayOfWeekNameShort]    AS  [DayOfWeekNameShort]#(lf)        ,[WeekWeekday]#(lf)        ,[YearWeekWeekday]#(lf)        ,[IsWorkingday]#(lf)        ,[WorkingdayNumber]#(lf)        ,[IsToday]#(lf)        ,[IsCurrentWeek]#(lf)        ,[IsCurrentMonth]#(lf)        ,[IsCurrentQuarter]#(lf)        ,[IsCurrentSemester]#(lf)        ,[IsCurrentYear]#(lf)        ,[IsLeapYear]#(lf)        ,[IsInCurrentWindow]#(lf)        ,[YearIndex]#(lf)        ,[YearIndex_Name]#(lf)        ,[QuarterIndex]#(lf)        ,[SemesterIndex]#(lf)        ,[MonthIndex]#(lf)        ,[WeekIndex]#(lf)        ,[DayIndex]#(lf)    FROM [dbo].[Date]#(lf)        WHERE [Year] BETWEEN 2022 AND 2026;#(lf)"])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation LinkedQueryName = Date

