expression L4L_Dates =
		let
		    Source = Sql.Database(SourceServer, ContosoRetailDW_DB, [Query="WITH [Source]#(lf)AS#(lf)(SELECT [St].[StoreKey]#(lf)        ,[St].[GeographyKey]#(lf)        ,[St].[Status]#(lf)        ,DATEADD(yyyy, 13, CONVERT(date, [St].[OpenDate])) AS  [OpenDate]#(lf)    FROM [dbo].[DimStore]   AS  [St]#(lf)        INNER JOIN [dbo].[DimGeography]     AS  [G]#(lf)            ON [G].[GeographyKey] = [St].[GeographyKey]#(lf)        WHERE [G].[RegionCountryName] = 'Italy')#(lf), [Result]#(lf)AS#(lf)(SELECT [StoreKey]#(lf)        ,[GeographyKey]#(lf)        ,CASE [StoreKey]#(lf)            WHEN 225#(lf)                THEN CONVERT(date, '20240701')#(lf)            WHEN 224#(lf)                THEN CONVERT(date, '20240531')#(lf)            WHEN 226#(lf)                THEN CONVERT(date, '20241031')#(lf)            ELSE [OpenDate]#(lf)         END                AS  [OpenDate]#(lf)        ,CASE [StoreKey]#(lf)            WHEN 222#(lf)                THEN CONVERT(date, '20240831')#(lf)            WHEN 225#(lf)                THEN CONVERT(date, '20240331')#(lf)            ELSE CONVERT(date, '20301231')#(lf)         END                AS  [CloseDate]#(lf)        ,CASE [StoreKey]#(lf)            WHEN 224#(lf)                THEN 2  --  Opening#(lf)            WHEN 226#(lf)                THEN 2  --  Opening#(lf)            WHEN 222#(lf)                THEN 3  --  Closing#(lf)            WHEN 225#(lf)                THEN 4  --  Refresh#(lf)            ELSE 1      --  Comparable#(lf)         END                AS  [L4L_Status_Src]#(lf)    FROM [Source]#(lf)    )#(lf)SELECT [StoreKey]#(lf)        ,[GeographyKey]#(lf)        ,[OpenDate]#(lf)        ,[CloseDate]#(lf)        ,EOMONTH([OpenDate])    AS  [OpenDate_EOM]#(lf)        ,EOMONTH([CloseDate])   AS  [CloseDate_EOM]#(lf)        ,[L4L_Status_Src]#(lf)    FROM [Result]#(lf)ORDER BY [StoreKey]#(lf)            ,[OpenDate];#(lf)#(lf)"]),
		    #"Changed Type" = Table.TransformColumnTypes(Source,{{"OpenDate", type date}, {"CloseDate", type date}, {"OpenDate_EOM", type date}, {"CloseDate_EOM", type date}})
		in
		    #"Changed Type"
	lineageTag: 5beb3a52-1463-49ef-91b9-9bf4bb31b08e

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

